{
  "policy_format_version": "0.3.0",
  "repository_kind": "tooling",
  "paths": {
    "forbidden": [],
    "canonical_docs": ["README.md"],
    "governance_paths": ["repo-policy.json"]
  },
  "diff_rules": {
    "max_new_docs": 2,
    "max_new_files": 10
  },
  "content_rules": [
    {
      "id": "old-form-rule",
      "pattern": "TODO",
      "severity": "warn",
      "message": "No TODOs allowed"
    }
  ],
  "cochange_rules": []
}
