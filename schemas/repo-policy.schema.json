{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/netkeep80/repo-guard/schemas/repo-policy.schema.json",
  "title": "Repository Policy",
  "type": "object",
  "required": [
    "policy_format_version",
    "repository_kind",
    "paths",
    "diff_rules",
    "content_rules",
    "cochange_rules"
  ],
  "additionalProperties": false,
  "properties": {
    "policy_format_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "repository_kind": {
      "type": "string",
      "enum": ["library", "application", "tooling", "documentation"]
    },
    "enforcement": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "description": "Optional default enforcement behavior. CLI or Action invocation can override it.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["advisory", "blocking"],
          "description": "advisory reports policy violations as warnings and exits 0; blocking enforces violations with exit 1."
        }
      }
    },
    "paths": {
      "type": "object",
      "required": ["forbidden", "canonical_docs", "governance_paths"],
      "additionalProperties": false,
      "properties": {
        "forbidden": {
          "type": "array",
          "items": { "type": "string" }
        },
        "canonical_docs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "governance_paths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Canonical list of paths that define repository governance. Informational only; not enforced at runtime. Used to document which files control policy."
        },
        "operational_paths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for operational bot-artifact files that are allowed as special-case paths in diffs"
        },
        "public_api": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Reserved for future use. Accepted by schema but not enforced at runtime. Non-empty values will produce a diagnostic warning."
        }
      }
    },
    "diff_rules": {
      "type": "object",
      "required": ["max_new_docs", "max_new_files"],
      "additionalProperties": false,
      "properties": {
        "max_new_docs": {
          "type": "integer",
          "minimum": 0
        },
        "max_new_files": {
          "type": "integer",
          "minimum": 0
        },
        "max_net_added_lines": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "content_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "glob", "mode", "forbid_regex"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "glob": { "type": "string" },
          "mode": {
            "type": "string",
            "enum": ["added_lines"]
          },
          "forbid_regex": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },
    "cochange_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["if_changed", "must_change_any"],
        "additionalProperties": false,
        "properties": {
          "if_changed": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "must_change_any": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    }
  }
}
