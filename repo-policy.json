{
  "policy_format_version": "0.3.0",
  "repository_kind": "tooling",
  "enforcement": {
    "mode": "blocking"
  },
  "paths": {
    "forbidden": [
      "docs/phase-*",
      "docs/history-*",
      "*.bak"
    ],
    "canonical_docs": [
      "README.md"
    ],
    "governance_paths": [
      "repo-policy.json",
      "schemas/"
    ],
    "operational_paths": [
      ".claude/**",
      ".gitkeep"
    ]
  },
  "diff_rules": {
    "max_new_docs": 2,
    "max_new_files": 15,
    "max_net_added_lines": 2000
  },
  "content_rules": [
    {
      "id": "no-todo-without-issue",
      "glob": "**",
      "mode": "added_lines",
      "forbid_regex": ["TODO(?!\\(#\\d+\\))"]
    }
  ],
  "cochange_rules": [
    {
      "if_changed": ["src/**"],
      "must_change_any": ["tests/**"]
    }
  ]
}
