{
  "policy_format_version": "0.1.0",
  "repository_kind": "tooling",
  "paths": {
    "forbidden": [
      "docs/phase-*",
      "docs/history-*",
      "*.bak"
    ],
    "canonical_docs": [
      "README.md"
    ],
    "governance_paths": [
      "repo-policy.json",
      "schemas/"
    ]
  },
  "diff_rules": {
    "max_new_docs": 2,
    "max_new_files": 10
  },
  "content_rules": [
    {
      "id": "no-todo-without-issue",
      "pattern": "TODO(?!\\(#\\d+\\))",
      "severity": "warn",
      "message": "TODO comments must reference an issue: TODO(#123)"
    }
  ],
  "cochange_rules": []
}
